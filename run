#!/usr/bin/bash

dir="build"

build=""
if [ -f /usr/bin/ninja ]; then
    build="-G Ninja"
fi

options="-DKokkos_ENABLE_OPENMP=ON"
export OMP_NUM_THREADS=$(lscpu -p | egrep -v '^#' | sort -u -t, -k 2,4 | wc -l)
export OMP_PROC_BIND=true
export OMP_PLACES=cores

if [[ $1 == "--cuda" ]]; then
    options="-DKokkos_ENABLE_CUDA=ON -DKokkosKernels_ENABLE_TPL_CUBLAS=ON -DKokkosKernels_ENABLE_TPL_CUSOLVER=ON"
    dir=build-cuda
fi

if [[ $1 == "--hip" ]]; then
    options="-DKokkos_ENABLE_HIP=ON -DKokkosKernels_ENABLE_TPL_ROCBLAS=ON -DKokkosKernels_ENABLE_TPL_ROCSOLVER=ON -DKokkosKernels_ENABLE_TPL_ROCSPARSE=ON -DKokkos_ENABLE_ROCTHRUST=OFF"
    export CC=hipcc
    export CXX=hipcc
    export hip_DIR=/opt/rocm/lib/cmake/hip/
    export rocblas_DIR=/opt/rocm/lib/cmake/rocblas
    export ROCBLAS_DIR=/opt/rocm/lib/cmake/rocblas
    export ROCSOLVER_DIR=/opt/rocm/lib/cmake/rocsolver
    export ROCSPARSE_DIR=/opt/rocm/lib/cmake/rocsparse
    # export rocprofiler-sdk-roctx_DIR=/opt/rocm/lib
    # export ROCM_ROCTX_LIB=/opt/rocm/lib/libroctx64.so
    dir=build-hip
fi

cmake -B $dir $options $build \
    -DCMAKE_BUILD_TYPE=Release \
    -DKokkosKernels_ENABLE_COMPONENT_COMMON=ON \
    -DKokkosKernels_ENABLE_COMPONENT_BATCHED=OFF \
    -DKokkosKernels_ENABLE_COMPONENT_BLAS=ON \
    -DKokkosKernels_ENABLE_COMPONENT_LAPACK=ON \
    -DKokkosKernels_ENABLE_COMPONENT_GRAPH=OFF \
    -DKokkosKernels_ENABLE_COMPONENT_SPARSE=OFF \
    -DKokkosKernels_ENABLE_COMPONENT_ODE=OFF || exit
cmake --build $dir || exit
time $dir/src/main $2 $3 $4 || exit